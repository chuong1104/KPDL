# .env — Copy file này, KHÔNG commit lên Git

# ── MinIO ──────────────────────────────────────────
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password123
MINIO_ENDPOINT=localhost:9000
MINIO_SECURE=false

# ── Bucket names ────────────────────────────────────
BRONZE_BUCKET=electronics-bronze
SILVER_BUCKET=electronics-silver
GOLD_BUCKET=electronics-gold

# ── Spark ───────────────────────────────────────────
SPARK_MASTER=local[*]
SPARK_DRIVER_MEMORY=4g
SPARK_EXECUTOR_MEMORY=4g
SPARK_SHUFFLE_PARTITIONS=8

# ── Pipeline config ─────────────────────────────────
SAMPLE_FRACTION=0.10
RANDOM_SEED=42
MIN_REVIEWS_PER_USER=5
MIN_REVIEWS_PER_ITEM=10

# ── HuggingFace (optional - chỉ cần nếu dùng private dataset) ──
HF_TOKEN=
